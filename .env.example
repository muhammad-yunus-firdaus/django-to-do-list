# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES - Manajemen Tugas
# Copy file ini menjadi .env dan isi dengan nilai yang sesuai
# ═══════════════════════════════════════════════════════════════════════════

# ── Django Core Settings ───────────────────────────────────────────────────
# WAJIB: Generate secret key baru untuk production
# Generate dengan: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here-change-this-in-production

# Debug mode - WAJIB False di production!
DEBUG=True

# Allowed hosts - Pisahkan dengan koma untuk multiple hosts
# Production example: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-username.pythonanywhere.com
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Database Configuration ─────────────────────────────────────────────────
# SQLite (default untuk development)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (untuk production - optional)
# DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# MySQL (alternative)
# DATABASE_URL=mysql://username:password@localhost:3306/dbname

# ── Email Configuration (Optional) ─────────────────────────────────────────
# Untuk notifikasi email di masa depan
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── Additional Settings (Optional) ─────────────────────────────────────────
# Timezone
TIME_ZONE=Asia/Jakarta

# Language
LANGUAGE_CODE=id
